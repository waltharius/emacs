# ============================================================
# PRIVACY PROTECTION - Files that may contain note titles/paths
# ============================================================

# Session state (contains full file paths with note titles!)
recentf
recentf~
places
bookmarks
bookmarks~
saveplace
ido.last
savehist
history

# Desktop sessions (complete session state - all open files!)
desktop/
*.desktop
*.desktop.lock
.emacs.desktop
.emacs.desktop.lock

# Org-mode (may contain note locations and titles)
.org-id-locations
.org-clock-save
.org-clock-save.el
org-clock-save.el
org-roam.db
org-roam.db-shm
org-roam.db-wal

# Project/completion caches (file paths)
projectile-bookmarks.eld
projectile.cache
smex-items

# ============================================================
# TYPING ANALYTICS DATA - Privacy sensitive keystroke data
# ============================================================

# Character-level typing data (timestamps + keystrokes)
keys

# Command frequency statistics
.emacs.keyfreq

# ============================================================
# SYNCTHING CONFLICTS - Never commit these!
# ============================================================

.stversions/
*.sync-conflict-*
*sync-conflict*

# ============================================================
# INSTALLED PACKAGES - Auto-downloaded, don't version
# ============================================================

elpa/
elpa.backup/
elpaca/
straight/
quelpa/
eln-cache/

# ============================================================
# CACHE AND TEMPORARY FILES
# ============================================================

auto-save-list/
transient/
url/
eshell/
network-security.data

# Undo-tree history
undo-tree-history/
.undo-tree-*

# Compiled files
*.elc

# ============================================================
# BACKUP AND AUTOSAVE FILES
# ============================================================

# Emacs backups
*~
\#*\#
.\#*
*.backup
*.backup.*
.backups/
.autosaves/

# Version backups
init.el_v*.txt

# ============================================================
# SYSTEM FILES
# ============================================================

.DS_Store
Thumbs.db

# ============================================================
# TUTORIAL (not needed in git)
# ============================================================

tutorial/

# ============================================================
# SESSION COOKIES AND AUTHENTICATION TOKENS
# ============================================================

# curl/request.el cookie jar (may contain session tokens!)
request/curl-cookie-jar
curl-cookie-jar

# ============================================================
# KEEP ONLY CONFIGURATION FILES
# ============================================================
# Everything above is ignored, but these are explicitly tracked:

!init.el
!early-init.el
!modules/
!.gitignore
!README.md
